{
  "version": 2,
  "buildCommand": "npm run build || echo 'No build needed'",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "$1"
    },
    {
      "src": "/customer-portal",
      "dest": "/customer-portal.html"
    },
    {
      "src": "/admin",
      "dest": "/loyalty_with_registration.html"
    },
    {
      "src": "/badge",
      "dest": "/qr-badge-generator.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
