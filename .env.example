# THE VIEW GROUP - Environment Variables
# Rename this file to .env and fill in your actual values

# Phase 1 (Frontend)
VITE_APP_NAME=THE VIEW Loyalty
VITE_APP_VERSION=1.0.0
VITE_API_URL=http://localhost:3000

# Phase 2 (Backend)
NODE_ENV=production
PORT=3000
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/theview
JWT_SECRET=your_super_secret_jwt_key_here

# Database
DB_HOST=localhost
DB_PORT=27017
DB_NAME=theview_loyalty
DB_USER=admin
DB_PASSWORD=secure_password

# Services
SENDGRID_API_KEY=your_sendgrid_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE=+1234567890

# SMS Provider
SMS_API_KEY=your_sms_provider_key
SMS_FROM=THE VIEW

# Email
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# LINE Integration (Phase 2)
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_ACCESS_TOKEN=your_line_access_token

# Google Services
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key

# Security
CORS_ORIGIN=https://the-view-loyalty.vercel.app
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=/logs/app.log

# Feature Flags
ENABLE_PHONE_OTP=true
ENABLE_EMAIL_NOTIFICATION=true
ENABLE_SMS_REMINDER=false
ENABLE_LINE_BOT=false
ENABLE_MULTI_BRANCH=false

# Phase 3 Features
ENABLE_ANALYTICS=false
ENABLE_AI_RECOMMENDATIONS=false
ENABLE_MACHINE_LEARNING=false

# Development Only
DEBUG=false
MOCK_DATA=false
TEST_MODE=false
